{
    "name": "thomas-0816/laravel-duckdb",
    "version": "1.0.0",
    "description": "DuckDB driver for Laravel",
    "keywords": ["laravel", "duckdb", "database", "analytics"],
    "license": "MIT",
    "authors": [
        {
            "name": "Thomas Bley"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-pdo_duckdb": "*",
        "illuminate/database": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "DuckDb\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DuckDb\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DuckDb\\DuckDbServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3",
        "pestphp/pest": "^3.7"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "phpcsfixer": "php-cs-fixer fix --allow-risky=yes --diff",
        "phpstan": "phpstan analyse",
        "pest": "pest --coverage",
        "test": ["@phpcsfixer", "@phpstan", "@pest"]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
